# AWS (Lambda uses IAM role in production, use these for local testing only)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Supabase (service role — never expose to clients)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic (for AI verdicts via direct API)
ANTHROPIC_API_KEY=

# DynamoDB
DYNAMODB_TABLE=gone-leaderboard

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=gone-photos
R2_PUBLIC_URL=https://photos.gone.app
