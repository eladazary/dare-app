# Supabase (available automatically in edge functions as SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY)
# Set these via: supabase secrets set KEY=value

ANTHROPIC_API_KEY=
OPENWEATHER_API_KEY=
EXPO_PUSH_TOKEN_SECRET=

# Cloudflare R2 (for presigned URL generation)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=gone-photos
R2_PUBLIC_URL=https://photos.gone.app
